[settings]
experimental = true
disable_default_registry = true
disable_backends = ["asdf", "vfox"]
idiomatic_version_file_enable_tools = ["python", "npm", "bun"]
minimum_release_age = "7d"
paranoid = true
yes = true

[settings.pipx]
uvx = true

[settings.npm]
package_manager = "bun"

[settings.github]
credential_command = "gh auth token"

[bootstrap.packages] # experimental
{{- if eq .chezmoi.os "darwin" }}
# macOS
"brew:autoconf" = "latest"
"brew:gmp" = "latest"
"brew:libyaml" = "latest"
"brew:openssl@3" = "latest"
"brew:pkg-config" = "latest"
"brew:readline" = "latest"
"brew:sqlite3" = "latest"
"brew:tcl-tk@8" = "latest"
"brew:xz" = "latest"
"brew:zlib" = "latest"
{{- else if eq .chezmoi.os "linux" }}
{{- if or (eq .chezmoi.osRelease.id "debian") (contains "debian" (.chezmoi.osRelease.idLike | default "")) }}
# Debian / Ubuntu
"apt:autoconf" = "latest"
"apt:build-essential" = "latest"
"apt:curl" = "latest"
"apt:git" = "latest"
"apt:libffi-dev" = "latest"
"apt:libgmp-dev" = "latest"
"apt:libssl-dev" = "latest"
"apt:libyaml-dev" = "latest"
"apt:zlib1g-dev" = "latest"
{{- end }}
{{- end }}

