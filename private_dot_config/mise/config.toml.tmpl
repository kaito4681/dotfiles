[tasks.update]
description = "Update all tools"
# sudo のパスワード入力だけ先に単独で済ませ(プロンプトが他タスクの出力に
# 埋もれないように)、以降は update:packages も含めて全部並列(:::)で回す。
run = [
{{- if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "debian") (contains "debian" (.chezmoi.osRelease.idLike | default ""))) }}
	"sudo -v",
{{- end }}
	"mise run update:packages ::: update:mise ::: update:uv ::: update:sheldon{{ if eq .chezmoi.os "darwin" }} ::: update:brew{{ end }}",
]

[tasks."update:packages"]
run = [
{{- if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "debian") (contains "debian" (.chezmoi.osRelease.idLike | default ""))) }}
	# apt の更新で sudo を使うが、mise のサブプロセスは TTY を持たずパスワードを聞けない。
	# 先にここで認証してクレデンシャルをキャッシュさせておく。
	"sudo -v",
{{- end }}
	"mise bootstrap packages upgrade -y",
]

{{- if eq .chezmoi.os "darwin" }}
[tasks."update:brew"]
run = ["mise bootstrap packages upgrade --brew", "brew update", "brew upgrade", "brew cleanup"]
{{- end }}


[tasks."update:mise"]
run = [
	"mise plugin uninstall --all",
	"mise self-update -y",
	"mise upgrade -y",
	# "MISE_MINIMUM_RELEASE_AGE=7d mise prune --tools -y",
	"mise prune --configs -y",
]
[tasks."update:uv"]
run = [
	"uv tool upgrade --all",
	# uv の実行中ジョブがある間は cache prune がロック待ちで固まるのでスキップ
	"pgrep -f 'uv run' >/dev/null || uv cache prune -v",
]

[tasks."update:sheldon"]
run = ["sheldon lock --update"]

[tasks.setup]
run = ["mise bootstrap packages install --update", "mise install", "sheldon lock --update"]
